# =============================================================================
# ProfPay — PRODUCTION .env
# Скопируй:  cp .env.production.example .env
# Заполни ВСЕ поля перед первым запуском!
# =============================================================================

# ---- Первый администратор (создаётся при первом запуске) ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ЗАМЕНИ_НА_НАДЁЖНЫЙ_ПАРОЛЬ

# ---- PostgreSQL ----
POSTGRES_USER=profpay_user
POSTGRES_PASSWORD=ЗАМЕНИ_НА_НАДЁЖНЫЙ_ПАРОЛЬ_БД
POSTGRES_DB=profpay_db

# ---- JWT / Сессии ----
# Сгенерируй: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=ЗАМЕНИ_НА_СГЕНЕРИРОВАННЫЙ_КЛЮЧ

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Режим отладки (false для продакшена!) ----
DEBUG=false
